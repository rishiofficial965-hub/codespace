# --- Stage 1: Build the React Application ---
FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build  # Compiles code into /app/dist

# --- Stage 2: Serve the Static Files via Nginx ---
FROM nginx:alpine
# Copy the built files from Stage 1 into Nginx default serve path
COPY --from=builder /app/dist /usr/share/nginx/html

# Copy a custom nginx configuration to handle React Router client-side routing
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
